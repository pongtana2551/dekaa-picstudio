# TikTok credentials from https://developers.tiktok.com/ → Manage apps
TIKTOK_CLIENT_KEY=sbxxxxxxxxxxxxxxxxxx
TIKTOK_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Must EXACTLY match the redirect URI configured in the TikTok developer portal
TIKTOK_REDIRECT_URI=https://dekaa-picstudio.vercel.app/api/auth/callback

# INBOX = sandbox/draft (review still in progress)
# DIRECT = production direct post (only after audit approval)
TIKTOK_POST_MODE=INBOX

# 32+ random chars used to encrypt the session cookie
# Generate with: openssl rand -hex 32
SESSION_PASSWORD=replace-me-with-32-plus-random-characters-1234567890
